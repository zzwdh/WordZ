<Page
    x:Class="WordZ.Windows.Pages.CollocatePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel Padding="0,0,0,12" Spacing="16">
            <TextBlock FontSize="24" FontWeight="SemiBold" Text="Collocate" />
            <TextBlock Text="{Binding ResultSummary}" TextWrapping="Wrap" />

            <TextBox
                Header="Node word"
                PlaceholderText="Enter the keyword to analyze"
                Text="{Binding Query, Mode=TwoWay}" />

            <StackPanel Orientation="Horizontal" Spacing="12">
                <ComboBox
                    Width="360"
                    Header="Scope"
                    DisplayMemberPath="Label"
                    ItemsSource="{Binding ScopeOptions}"
                    SelectedItem="{Binding SelectedScope, Mode=TwoWay}" />
                <TextBox Width="120" Header="Window size" Text="{Binding WindowSize, Mode=TwoWay}" />
                <TextBox Width="140" Header="Minimum frequency" Text="{Binding MinimumFrequency, Mode=TwoWay}" />
                <Button
                    VerticalAlignment="Bottom"
                    Command="{Binding RunAnalysisCommand}"
                    Content="Run collocate" />
                <ProgressRing
                    Width="24"
                    Height="24"
                    VerticalAlignment="Bottom"
                    IsActive="{Binding IsRunning}" />
            </StackPanel>

            <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" />
            <TextBlock Text="{Binding Shell.RuntimeSummary}" TextWrapping="Wrap" />

            <ListView ItemsSource="{Binding Rows}" MaxHeight="420" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="56" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="96" />
                                <ColumnDefinition Width="96" />
                                <ColumnDefinition Width="96" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Rank}" />
                            <TextBlock Grid.Column="1" Text="{Binding Word}" />
                            <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="{Binding Total}" />
                            <TextBlock Grid.Column="3" HorizontalAlignment="Right" Text="{Binding Left}" />
                            <TextBlock Grid.Column="4" HorizontalAlignment="Right" Text="{Binding RateDisplay}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </ScrollViewer>
</Page>
