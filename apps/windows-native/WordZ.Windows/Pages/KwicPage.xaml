<Page
    x:Class="WordZ.Windows.Pages.KwicPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="8" BorderBrush="#FFD0D0D0" BorderThickness="1">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240" />
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBox
                    Grid.Column="0"
                    Header="Search Query"
                    PlaceholderText="Keyword"
                    Text="{Binding Query, Mode=TwoWay}" />
                <ComboBox
                    Grid.Column="1"
                    Header="Results Set"
                    DisplayMemberPath="Label"
                    ItemsSource="{Binding ScopeOptions}"
                    SelectedItem="{Binding SelectedScope, Mode=TwoWay}" />
                <ComboBox
                    Grid.Column="2"
                    Header="Sort"
                    ItemsSource="{Binding SortModeOptions}"
                    SelectedItem="{Binding SelectedSortMode, Mode=TwoWay}" />
                <TextBox
                    Grid.Column="3"
                    Header="Left"
                    Text="{Binding LeftContextSize, Mode=TwoWay}" />
                <TextBox
                    Grid.Column="4"
                    Header="Right"
                    Text="{Binding RightContextSize, Mode=TwoWay}" />
                <Button
                    Grid.Column="5"
                    VerticalAlignment="Bottom"
                    Command="{Binding RunSearchCommand}"
                    Content="Start" />
                <TextBlock
                    Grid.Column="6"
                    VerticalAlignment="Bottom"
                    Text="{Binding ResultSummary}"
                    TextWrapping="Wrap" />
            </Grid>
        </Border>

        <Grid
            Grid.Row="1"
            Padding="8,0,8,0"
            ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="110" />
            </Grid.ColumnDefinitions>
            <TextBlock FontWeight="SemiBold" Text="File" />
            <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="Left Context" />
            <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="Hit" />
            <TextBlock Grid.Column="3" FontWeight="SemiBold" Text="Right Context" />
            <TextBlock Grid.Column="4" FontWeight="SemiBold" Text="Locator" />
        </Grid>

        <ListView
            Grid.Row="2"
            ItemsSource="{Binding Rows}"
            SelectionMode="Single">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="8,6" BorderBrush="#11000000" BorderThickness="0,0,0,1">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="250" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="110" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock FontWeight="SemiBold" Text="{Binding CorpusName}" />
                                <TextBlock FontSize="12" Text="{Binding FolderName}" TextWrapping="Wrap" />
                            </StackPanel>
                            <TextBlock
                                Grid.Column="1"
                                FontFamily="Consolas"
                                Text="{Binding Left}"
                                TextWrapping="Wrap" />
                            <TextBlock
                                Grid.Column="2"
                                FontFamily="Consolas"
                                FontWeight="SemiBold"
                                Text="{Binding Node}"
                                TextWrapping="Wrap" />
                            <TextBlock
                                Grid.Column="3"
                                FontFamily="Consolas"
                                Text="{Binding Right}"
                                TextWrapping="Wrap" />
                            <Button
                                Grid.Column="4"
                                Tag="{Binding}"
                                Click="OnLocateClick"
                                Content="Locate" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel Grid.Row="3" Margin="8,0,8,0" Spacing="4">
            <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" />
            <TextBlock Text="{Binding Shell.RuntimeSummary}" TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</Page>
