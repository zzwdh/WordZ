<Page
    x:Class="WordZ.Windows.Pages.LocatorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="8" BorderBrush="#FFD0D0D0" BorderThickness="1">
                <StackPanel Spacing="6">
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Locator" />
                    <TextBlock FontWeight="SemiBold" Text="{Binding CorpusTitle}" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding FolderTitle}" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding TargetSummary}" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding ResultSummary}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Padding="8" BorderBrush="#FFD0D0D0" BorderThickness="1">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280" />
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBox
                        Grid.Column="0"
                        Header="Keyword"
                        IsReadOnly="True"
                        Text="{Binding Keyword}" />
                    <TextBox
                        Grid.Column="1"
                        Header="Left"
                        Text="{Binding LeftContextSize, Mode=TwoWay}" />
                    <TextBox
                        Grid.Column="2"
                        Header="Right"
                        Text="{Binding RightContextSize, Mode=TwoWay}" />
                    <Button
                        Grid.Column="3"
                        VerticalAlignment="Bottom"
                        Command="{Binding RunLocatorCommand}"
                        Content="Locate" />
                    <TextBlock
                        Grid.Column="4"
                        VerticalAlignment="Bottom"
                        Text="{Binding StatusText}"
                        TextWrapping="Wrap" />
                </Grid>
            </Border>
        </Grid>

        <Grid
            Grid.Row="1"
            Padding="8,0,8,0"
            ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="120" />
            </Grid.ColumnDefinitions>
            <TextBlock FontWeight="SemiBold" Text="Sentence" />
            <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="Left Context" />
            <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="Hit" />
            <TextBlock Grid.Column="3" FontWeight="SemiBold" Text="Right Context / Sentence" />
            <TextBlock Grid.Column="4" FontWeight="SemiBold" Text="Status" />
        </Grid>

        <ListView
            Grid.Row="2"
            ItemsSource="{Binding Rows}"
            SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="8,6" BorderBrush="#11000000" BorderThickness="0,0,0,1">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="240" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding SentenceId}" />
                            <TextBlock
                                Grid.Column="1"
                                FontFamily="Consolas"
                                Text="{Binding LeftWords}"
                                TextWrapping="Wrap" />
                            <TextBlock
                                Grid.Column="2"
                                FontFamily="Consolas"
                                FontWeight="SemiBold"
                                Text="{Binding NodeWord}"
                                TextWrapping="Wrap" />
                            <StackPanel Grid.Column="3" Spacing="2">
                                <TextBlock FontFamily="Consolas" Text="{Binding RightWords}" TextWrapping="Wrap" />
                                <TextBlock Foreground="#99000000" Text="{Binding Text}" TextWrapping="Wrap" />
                            </StackPanel>
                            <TextBlock
                                Grid.Column="4"
                                FontWeight="SemiBold"
                                Text="{Binding Status}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock
            Grid.Row="3"
            Margin="8,0,8,0"
            Text="{Binding Shell.RuntimeSummary}"
            TextWrapping="Wrap" />
    </Grid>
</Page>
