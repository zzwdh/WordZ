<Page
    x:Class="WordZ.Windows.Pages.LibraryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid ColumnSpacing="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Padding="8" BorderBrush="#FFD0D0D0" BorderThickness="1">
            <StackPanel Spacing="8">
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Target Corpus" />
                <TextBlock Text="{Binding Shell.LibrarySummaryText}" TextWrapping="Wrap" />
                <TextBlock Text="{Binding Shell.WorkspaceSelectionSummary}" TextWrapping="Wrap" />
                <TextBlock Text="{Binding Shell.UserDataDirectory}" TextWrapping="Wrap" />

                <ComboBox
                    Header="Folder Scope"
                    DisplayMemberPath="Label"
                    ItemsSource="{Binding FolderOptions}"
                    SelectedItem="{Binding SelectedFolderOption, Mode=TwoWay}" />

                <TextBlock FontWeight="SemiBold" Text="Folders" />
                <ListView ItemsSource="{Binding Shell.Folders}" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Padding="0,4" Spacing="2">
                                <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                <TextBlock FontSize="12" Text="{Binding Subtitle}" TextWrapping="Wrap" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="180" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Padding="8" BorderBrush="#FFD0D0D0" BorderThickness="1">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Click="OnImportFilesClick" Content="Import Files" />
                        <Button Click="OnCreateFolderClick" Content="New Folder" />
                        <Button Command="{Binding RefreshLibraryCommand}" Content="Refresh" />
                        <Button Command="{Binding OpenSelectedCorpusCommand}" Content="Open Selected" />
                        <Button Click="OnDeleteSelectedCorpusClick" Content="Delete Selected" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Command="{Binding UseVisibleAsWorkspaceCommand}" Content="Use Visible as Workspace" />
                        <Button Command="{Binding UseAllAsWorkspaceCommand}" Content="Use All Corpora" />
                        <Button Command="{Binding ClearWorkspaceSelectionCommand}" Content="Clear Workspace" />
                        <Button Command="{Binding ApplyWorkspaceSelectionCommand}" Content="Apply Workspace" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Grid
                Grid.Row="1"
                Padding="8,0,8,0"
                ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="140" />
                </Grid.ColumnDefinitions>
                <TextBlock FontWeight="SemiBold" Text="Set" />
                <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="Corpus" />
                <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="Folder / File" />
                <TextBlock Grid.Column="3" FontWeight="SemiBold" Text="Type" />
                <TextBlock Grid.Column="4" FontWeight="SemiBold" Text="Updated" />
            </Grid>

            <ListView
                Grid.Row="2"
                ItemsSource="{Binding Shell.VisibleItems}"
                SelectedItem="{Binding SelectedCorpus, Mode=TwoWay}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="8,6" BorderBrush="#11000000" BorderThickness="0,0,0,1">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="140" />
                                </Grid.ColumnDefinitions>

                                <CheckBox
                                    VerticalAlignment="Center"
                                    IsChecked="{Binding IsInWorkspace, Mode=TwoWay}" />

                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                    <TextBlock FontSize="12" Text="{Binding Subtitle}" TextWrapping="Wrap" />
                                </StackPanel>

                                <TextBlock Grid.Column="2" Text="{Binding FolderName}" TextWrapping="Wrap" />
                                <TextBlock Grid.Column="3" Text="{Binding SourceTypeLabel}" />
                                <TextBlock Grid.Column="4" Text="{Binding UpdatedAtDisplay}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Border Grid.Row="3" Padding="8" BorderBrush="#FFD0D0D0" BorderThickness="1">
                <Grid RowSpacing="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding PreviewTitle}" />
                    <TextBlock Grid.Row="1" Text="{Binding PreviewMetadata}" TextWrapping="Wrap" />
                    <ScrollViewer Grid.Row="2">
                        <TextBlock FontFamily="Consolas" Text="{Binding PreviewText}" TextWrapping="Wrap" />
                    </ScrollViewer>
                </Grid>
            </Border>

            <TextBlock
                Grid.Row="4"
                Margin="8,0,8,0"
                Text="{Binding StatusText}"
                TextWrapping="Wrap" />
        </Grid>
    </Grid>
</Page>
