<Page
    x:Class="WordZ.Windows.Pages.StatsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel Padding="0,0,0,12" Spacing="16">
            <TextBlock FontSize="24" FontWeight="SemiBold" Text="&#x7EDF;&#x8BA1;" />
            <TextBlock Text="{Binding ResultSummary}" TextWrapping="Wrap" />

            <StackPanel Orientation="Horizontal" Spacing="12">
                <ComboBox
                    Width="360"
                    Header="Scope"
                    DisplayMemberPath="Label"
                    ItemsSource="{Binding ScopeOptions}"
                    SelectedItem="{Binding SelectedScope, Mode=TwoWay}" />
                <ComboBox
                    Width="240"
                    Header="Profile"
                    ItemsSource="{Binding ProfileOptions}"
                    SelectedItem="{Binding SelectedProfile, Mode=TwoWay}" />
                <Button
                    VerticalAlignment="Bottom"
                    Command="{Binding RunAnalysisCommand}"
                    Content="Run statistics" />
                <ProgressRing
                    Width="24"
                    Height="24"
                    VerticalAlignment="Bottom"
                    IsActive="{Binding IsRunning}" />
            </StackPanel>

            <TextBox
                Header="Run notes"
                PlaceholderText="Describe the statistics slice you want to validate."
                Text="{Binding Notes, Mode=TwoWay}" />

            <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" />

            <Grid ColumnSpacing="16" RowSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Grid.Column="0" Padding="12" BorderBrush="#33000000" BorderThickness="1" CornerRadius="8">
                    <StackPanel Spacing="4">
                        <TextBlock FontWeight="SemiBold" Text="Corpora" />
                        <TextBlock FontSize="20" Text="{Binding CorpusCount}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="0" Grid.Column="1" Padding="12" BorderBrush="#33000000" BorderThickness="1" CornerRadius="8">
                    <StackPanel Spacing="4">
                        <TextBlock FontWeight="SemiBold" Text="Tokens" />
                        <TextBlock FontSize="20" Text="{Binding TokenCount}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="0" Padding="12" BorderBrush="#33000000" BorderThickness="1" CornerRadius="8">
                    <StackPanel Spacing="4">
                        <TextBlock FontWeight="SemiBold" Text="Types / TTR" />
                        <TextBlock FontSize="20" Text="{Binding TypeCount}" />
                        <TextBlock Text="{Binding TtrDisplay}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" Padding="12" BorderBrush="#33000000" BorderThickness="1" CornerRadius="8">
                    <StackPanel Spacing="4">
                        <TextBlock FontWeight="SemiBold" Text="STTR" />
                        <TextBlock FontSize="20" Text="{Binding SttrDisplay}" />
                        <TextBlock Text="{Binding Shell.LibrarySummaryText}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel Spacing="8">
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Top frequency rows" />
                <ListView ItemsSource="{Binding FrequencyRows}" MaxHeight="360" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="64" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="96" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Rank}" />
                                <TextBlock Grid.Column="1" Text="{Binding Word}" />
                                <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="{Binding Count}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

            <StackPanel Spacing="8">
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Corpus comparison snapshot" />
                <ListView ItemsSource="{Binding CorpusSummaries}" MaxHeight="240" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Padding="0,6" Spacing="2">
                                <TextBlock FontWeight="SemiBold" Text="{Binding CorpusName}" />
                                <TextBlock Text="{Binding FolderName}" />
                                <TextBlock Text="{Binding Summary}" TextWrapping="Wrap" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
