<Page
    x:Class="WordZ.Windows.Pages.PlaceholderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <StackPanel Padding="0,0,0,12" Spacing="12">
        <TextBlock FontSize="24" FontWeight="SemiBold" Text="{Binding Title}" />
        <TextBlock Text="{Binding Description}" TextWrapping="Wrap" />
        <TextBlock Text="{Binding Shell.EngineStatus}" TextWrapping="Wrap" />
    </StackPanel>
</Page>
