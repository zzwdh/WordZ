<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows10.0.19041.0</TargetFramework>
    <TargetPlatformMinVersion>10.0.19041.0</TargetPlatformMinVersion>
    <RootNamespace>WordZ.Windows</RootNamespace>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <AppxManifest>Package.appxmanifest</AppxManifest>
    <Platforms>x64;arm64</Platforms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWinUI>true</UseWinUI>
    <EnableMsixTooling>true</EnableMsixTooling>
    <WindowsPackageType>MSIX</WindowsPackageType>
    <WindowsAppSdkDeploymentManagerInitialize>false</WindowsAppSdkDeploymentManagerInitialize>
    <WindowsAppSdkBootstrapInitialize>true</WindowsAppSdkBootstrapInitialize>
    <WindowsAppSDKBootstrapAutoInitializeOptions_OnPackageIdentity_NoOp>true</WindowsAppSDKBootstrapAutoInitializeOptions_OnPackageIdentity_NoOp>
    <NativeRuntimeNodeModuleExcludes>..\..\..\node_modules\**\*.map;..\..\..\node_modules\**\*.md;..\..\..\node_modules\**\*.markdown;..\..\..\node_modules\**\*.d.ts;..\..\..\node_modules\**\*.ts;..\..\..\node_modules\**\LICENSE*;..\..\..\node_modules\**\CHANGELOG*;..\..\..\node_modules\**\CHANGES*;..\..\..\node_modules\**\CODE_OF_CONDUCT*;..\..\..\node_modules\**\CONTRIBUTING*;..\..\..\node_modules\**\SECURITY*;..\..\..\node_modules\**\README*;..\..\..\node_modules\**\release-please-manifest.json;..\..\..\node_modules\**\package-lock.json;..\..\..\node_modules\**\test\**;..\..\..\node_modules\**\tests\**;..\..\..\node_modules\**\__tests__\**;..\..\..\node_modules\**\testing\**;..\..\..\node_modules\**\example\**;..\..\..\node_modules\**\examples\**;..\..\..\node_modules\**\docs\**;..\..\..\node_modules\**\website\**;..\..\..\node_modules\**\bench\**;..\..\..\node_modules\**\benchmark\**;..\..\..\node_modules\**\benchmarks\**;..\..\..\node_modules\**\.github\**;..\..\..\node_modules\**\.eslintrc*;..\..\..\node_modules\**\.nycrc;..\..\..\node_modules\**\tsconfig*.json;..\..\..\node_modules\**\typedoc.json;..\..\..\node_modules\iconv-lite\types\**;..\..\..\node_modules\mammoth\browser\**;..\..\..\node_modules\mammoth\bin\**;..\..\..\node_modules\pdf-parse\bin\**;..\..\..\node_modules\pdf-parse\dist\pdf-parse\esm\**;..\..\..\node_modules\pdf-parse\dist\pdf-parse\web\**;..\..\..\node_modules\pdf-parse\dist\worker\**;..\..\..\node_modules\pdf-parse\dist\node\**;..\..\..\node_modules\pdfjs-dist\web\**;..\..\..\node_modules\pdfjs-dist\legacy\**;..\..\..\node_modules\pdfjs-dist\types\**;..\..\..\node_modules\pdfjs-dist\cmaps\**;..\..\..\node_modules\pdfjs-dist\iccs\**;..\..\..\node_modules\pdfjs-dist\image_decoders\**;..\..\..\node_modules\pdfjs-dist\standard_fonts\**;..\..\..\node_modules\pdfjs-dist\wasm\**;..\..\..\node_modules\pdfjs-dist\webpack.mjs</NativeRuntimeNodeModuleExcludes>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="1.6.250205002" />
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.2.2" />
  </ItemGroup>

  <ItemGroup>
    <NativeRuntimeNodeModule Include="@xmldom\xmldom" />
    <NativeRuntimeNodeModule Include="argparse" />
    <NativeRuntimeNodeModule Include="base64-js" />
    <NativeRuntimeNodeModule Include="bluebird" />
    <NativeRuntimeNodeModule Include="core-util-is" />
    <NativeRuntimeNodeModule Include="dingbat-to-unicode" />
    <NativeRuntimeNodeModule Include="duck" />
    <NativeRuntimeNodeModule Include="iconv-lite" />
    <NativeRuntimeNodeModule Include="immediate" />
    <NativeRuntimeNodeModule Include="inherits" />
    <NativeRuntimeNodeModule Include="isarray" />
    <NativeRuntimeNodeModule Include="jszip" />
    <NativeRuntimeNodeModule Include="lie" />
    <NativeRuntimeNodeModule Include="lop" />
    <NativeRuntimeNodeModule Include="mammoth" />
    <NativeRuntimeNodeModule Include="option" />
    <NativeRuntimeNodeModule Include="pako" />
    <NativeRuntimeNodeModule Include="path-is-absolute" />
    <NativeRuntimeNodeModule Include="pdf-parse" />
    <NativeRuntimeNodeModule Include="pdfjs-dist" />
    <NativeRuntimeNodeModule Include="process-nextick-args" />
    <NativeRuntimeNodeModule Include="readable-stream" />
    <NativeRuntimeNodeModule Include="safe-buffer" />
    <NativeRuntimeNodeModule Include="safer-buffer" />
    <NativeRuntimeNodeModule Include="setimmediate" />
    <NativeRuntimeNodeModule Include="sprintf-js" />
    <NativeRuntimeNodeModule Include="string_decoder" />
    <NativeRuntimeNodeModule Include="underscore" />
    <NativeRuntimeNodeModule Include="util-deprecate" />
    <NativeRuntimeNodeModule Include="xmlbuilder" />
  </ItemGroup>
  
  <ItemGroup>
    <Content Include="..\..\..\package.json" Link="package.json" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="..\..\..\analysisCore.mjs" Link="analysisCore.mjs" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="..\..\..\analysisWorker.mjs" Link="analysisWorker.mjs" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="..\..\..\corpusStorage.js" Link="corpusStorage.js" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="..\..\..\corpusFileReader.js" Link="corpusFileReader.js" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="..\..\..\diagnostics\**\*.js" Link="diagnostics\%(RecursiveDir)%(Filename)%(Extension)" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="..\..\..\storage\**\*.js" Link="storage\%(RecursiveDir)%(Filename)%(Extension)" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="..\..\..\main\helpers\inputGuards.js" Link="main\helpers\inputGuards.js" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="..\..\..\packages\wordz-contracts\src\**\*.mjs" Link="packages\wordz-contracts\src\%(RecursiveDir)%(Filename)%(Extension)" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="..\..\..\packages\wordz-engine-js\src\**\*.mjs" Link="packages\wordz-engine-js\src\%(RecursiveDir)%(Filename)%(Extension)" CopyToOutputDirectory="PreserveNewest" />
    <Content
      Include="..\..\..\node_modules\%(NativeRuntimeNodeModule.Identity)\**\*"
      Exclude="$(NativeRuntimeNodeModuleExcludes)"
      Link="node_modules\%(NativeRuntimeNodeModule.Identity)\%(RecursiveDir)%(Filename)%(Extension)"
      CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
</Project>
