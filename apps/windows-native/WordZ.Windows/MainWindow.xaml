<Window
    x:Class="WordZ.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="WordZ">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <CommandBar Grid.Row="0" DefaultLabelPosition="Right">
            <AppBarButton Label="快速打开" />
            <AppBarButton Label="导入并保存" />
            <AppBarButton Label="本地语料库" />
            <AppBarSeparator />
            <AppBarButton Label="统计" />
            <AppBarButton Label="设置" />
            <AppBarButton Label="帮助" />
        </CommandBar>

        <NavigationView Grid.Row="1" IsBackButtonVisible="Collapsed" PaneDisplayMode="Left">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="统计" />
                <NavigationViewItem Content="对比" />
                <NavigationViewItem Content="卡方" />
                <NavigationViewItem Content="词云" />
                <NavigationViewItem Content="Ngram" />
                <NavigationViewItem Content="KWIC" />
                <NavigationViewItem Content="Collocate" />
                <NavigationViewItem Content="定位" />
            </NavigationView.MenuItems>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="12" Padding="16">
                    <TextBlock Text="{Binding VersionText}" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="当前语料与会话" Style="{StaticResource TitleTextBlockStyle}" />
                    <TextBlock Text="{Binding WorkspaceSummary}" TextWrapping="Wrap" />
                    <TextBox Header="SearchQuery" PlaceholderText="SearchQuery" />
                    <ComboBox Header="KWIC Scope">
                        <x:String>当前语料</x:String>
                        <x:String>当前文件夹</x:String>
                        <x:String>全部本地语料</x:String>
                    </ComboBox>
                    <InfoBar
                        IsOpen="True"
                        Severity="Informational"
                        Title="Engine 状态"
                        Message="{Binding EngineStatus}" />
                </StackPanel>

                <Grid Grid.Column="1" Padding="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <InfoBar
                        Title="WordZ Windows Native"
                        Message="{Binding BuildSummary}"
                        IsOpen="True"
                        Severity="Informational" />
                    <TabView Grid.Row="1">
                        <TabViewItem Header="统计">
                            <Grid Padding="8">
                                <TextBlock Text="统计结果 DataGrid 将在这里挂载。" />
                            </Grid>
                        </TabViewItem>
                        <TabViewItem Header="KWIC">
                            <Grid Padding="8">
                                <TextBlock Text="KWIC DataGrid 将在这里挂载。" />
                            </Grid>
                        </TabViewItem>
                        <TabViewItem Header="Collocate">
                            <Grid Padding="8">
                                <TextBlock Text="Collocate DataGrid 将在这里挂载。" />
                            </Grid>
                        </TabViewItem>
                    </TabView>
                </Grid>
            </Grid>
        </NavigationView>

        <InfoBar
            Grid.Row="2"
            IsOpen="True"
            Severity="Informational"
            Title="WordZ Native Shell"
            Message="{Binding EngineStatus}" />
    </Grid>
</Window>
