{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wordz.invalid/schemas/jsonrpc-notification.schema.json",
  "title": "WordZ JSON-RPC notification",
  "type": "object",
  "required": ["jsonrpc", "method", "params"],
  "properties": {
    "jsonrpc": {
      "const": "2.0"
    },
    "method": {
      "type": "string",
      "minLength": 1
    },
    "params": {
      "type": ["object", "array", "null"]
    }
  },
  "additionalProperties": false
}
