{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wordz.invalid/schemas/jsonrpc-request.schema.json",
  "title": "WordZ JSON-RPC request",
  "type": "object",
  "required": ["jsonrpc", "id", "method"],
  "properties": {
    "jsonrpc": {
      "const": "2.0"
    },
    "id": {
      "type": ["string", "number"]
    },
    "method": {
      "type": "string",
      "minLength": 1
    },
    "params": {
      "type": ["object", "array", "null"]
    }
  },
  "additionalProperties": false
}
